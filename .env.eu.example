# =============================================================================
# loschke-chat — EU/Local Deployment Profile
# =============================================================================
#
# Dieses ENV-Profil konfiguriert die Plattform fuer EU/lokalen Betrieb.
# Keine Daten verlassen die EU (bzw. das lokale Netzwerk),
# ausser bei bewusst aktivierten Premium-Features (Gemini).
#
# Quick Start:
#   1. cp .env.eu.example .env
#   2. LLM Provider konfigurieren (mindestens einen)
#   3. docker-compose up -d
#   4. docker-compose exec app node -e "require('./seeds/run-seed.js')"
#   5. Open http://localhost:3000


# █████████████████████████████████████████████████████████████████████████████
# CORE
# █████████████████████████████████████████████████████████████████████████████

# --- Auth (Logto) ---
# Option A: Self-hosted Logto (docker-compose kann erweitert werden)
# Option B: Logto Cloud (SaaS, DSGVO-konform mit EU-Region)
LOGTO_APP_ID=
LOGTO_APP_SECRET=
LOGTO_ENDPOINT=https://auth.example.com
LOGTO_BASE_URL=http://localhost:3000
LOGTO_COOKIE_SECRET=mindestens-32-zeichen-langer-geheimer-schluessel

# --- Datenbank (docker-compose stellt PostgreSQL bereit) ---
DATABASE_URL=postgresql://loschke:loschke@postgres:5432/loschke_chat?sslmode=disable

# --- LLM Routing ---
# "direct" = Provider-SDKs direkt, kein Vercel Gateway noetig
LLM_ROUTING=direct

# --- Default-Modell ---
# Wird fuer neue User und als Fallback verwendet.
# Muss ein aktives Modell aus der DB sein (Admin > Models).
DEFAULT_MODEL_ID=mistral/mistral-large-latest

# AI_GATEWAY_API_KEY wird bei LLM_ROUTING=direct NICHT benoetigt.
# Alternativ: LLM_ROUTING=litellm fuer self-hosted LiteLLM Proxy:
# LITELLM_BASE_URL=http://litellm:4000/v1
# LITELLM_API_KEY=sk-litellm


# █████████████████████████████████████████████████████████████████████████████
# LLM PROVIDER — Mindestens einen konfigurieren
# █████████████████████████████████████████████████████████████████████████████

# --- Option 1: Mistral (EU, Paris) ---
# DSGVO-konform, schnelle Modelle, gutes Preis-Leistungs-Verhaeltnis.
# Modelle im Picker: mistral/mistral-large-latest, mistral/mistral-small-latest
MISTRAL_API_KEY=

# --- Option 2: IONOS AI Model Hub (DE, Frankfurt) ---
# Deutsche Cloud, OpenAI-kompatibel. Llama, Mistral, GPT-OSS Modelle.
# Modelle im Picker: ionos/meta-llama/Llama-3.3-70B-Instruct, etc.
# IONOS_API_TOKEN=

# --- Option 3: Ollama (Self-hosted, komplett lokal) ---
# Kein Internet noetig. Modelle lokal auf GPU/CPU.
# Modelle im Picker: ollama/llama3.1, ollama/mistral, etc.
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1


# █████████████████████████████████████████████████████████████████████████████
# FEATURES — EU/Local-kompatibel
# █████████████████████████████████████████████████████████████████████████████

# --- Storage (MinIO, docker-compose stellt bereit) ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=loschke-chat
S3_PUBLIC_DOMAIN=http://localhost:9000/loschke-chat

# --- Web Search (SearXNG, self-hosted) ---
# docker-compose --profile search up -d
SEARCH_PROVIDER=searxng
SEARXNG_URL=http://searxng:8080

# --- Memory (Mem0, self-hosted) ---
# docker-compose --profile memory up -d
# MEM0_BASE_URL=http://mem0:8080
# MEM0_API_KEY=mem0-local

# --- MCP Server (optional, self-hosted) ---
# MCP_ENABLED=true


# █████████████████████████████████████████████████████████████████████████████
# INSTANZ
# █████████████████████████████████████████████████████████████████████████████

NEXT_PUBLIC_BRAND=lernen
NEXT_PUBLIC_DEFAULT_THEME=dark

# Admin (E-Mail des Admins)
# SUPERADMIN_EMAIL=admin@example.com

# Credits (optional)
# NEXT_PUBLIC_CREDITS_ENABLED=true
# INITIAL_CREDITS=100
# CREDITS_PER_DOLLAR=100


# █████████████████████████████████████████████████████████████████████████████
# PREMIUM-FEATURES (optional, senden Daten an Google/Anthropic)
# █████████████████████████████████████████████████████████████████████████████
#
# Diese Features koennen auch im EU/Local-Profil aktiviert werden.
# WICHTIG: Es werden NUR Suchqueries/Prompts gesendet, keine internen Daten.
#
# | Feature          | Daten an Google       | Sensitivitaet |
# |------------------|-----------------------|---------------|
# | Deep Research    | Suchquery             | Gering        |
# | Image Generation | Text-Prompt           | Gering        |
# | TTS              | Sprechtext            | Mittel        |
# | YouTube Analyze  | Video-URL             | Gering        |

# GOOGLE_GENERATIVE_AI_API_KEY=
# DEEP_RESEARCH_ENABLED=true
# GOOGLE_SEARCH_ENABLED=true
# YOUTUBE_API_KEY=
# STITCH_API_KEY=

# Design-Library (externe Prompt-Formel-DB, EU Neon)
# DESIGN_LIBRARY_DATABASE_URL=postgresql://...

# Anthropic (Agent Skills: PPTX, XLSX, DOCX, PDF)
# ANTHROPIC_API_KEY=


# █████████████████████████████████████████████████████████████████████████████
# HINWEISE
# █████████████████████████████████████████████████████████████████████████████
#
# Experts & Skills:
#   Die mitgelieferten Seeds haben KEINE Model-Referenzen und funktionieren
#   mit jedem Provider. Wenn du ueber die Admin-UI Experts/Skills mit
#   modelPreference/modelId anlegst, nur verfuegbare EU/Local-Modelle nutzen.
#   Bei ungueltigem Model greift automatisch DEFAULT_MODEL_ID als Fallback.
