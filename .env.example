# =============================================================================
# build-jetzt — Environment Variables
# =============================================================================
#
# Kopiere diese Datei nach .env und fuelle die Werte aus.
# Nur die mit [PFLICHT] markierten Variablen sind fuer den Start noetig.
# Alles andere aktiviert optionale Features.
#
# Feature-Aktivierung:
#   - Opt-out (Default an):  chat, mermaid, darkMode
#   - Opt-in (Key setzen):   web/search, storage, mcp, admin, memory,
#                             imageGeneration, youtube, tts, branding, stitch
#   - Opt-in (Flag setzen):  businessMode, credits, deepResearch, googleSearch
#


# █████████████████████████████████████████████████████████████████████████████
# CORE — Pflicht fuer funktionierenden Betrieb
# █████████████████████████████████████████████████████████████████████████████

# =============================================================================
# AUTH — loschke-auth (OIDC) [PFLICHT]
# =============================================================================
# Zentrale OAuth-2.1-/OIDC-Lösung unter auth.loschke.ai. Pro Vercel-Instanz
# wird in loschke-auth ein eigener oauth_client + Organization angelegt;
# diese App authentifiziert sich mit dem zugehörigen Client-Secret.
# Ohne OIDC_CLIENT_ID: Dev-Bypass (alles frei zugaenglich, nur in NODE_ENV=development).

OIDC_ISSUER=https://auth.loschke.ai/api/auth
OIDC_AUTHORIZE_URL=https://auth.loschke.ai/api/auth/oauth2/authorize
OIDC_TOKEN_URL=https://auth.loschke.ai/api/auth/oauth2/token
OIDC_USERINFO_URL=https://auth.loschke.ai/api/auth/oauth2/userinfo
OIDC_END_SESSION_URL=https://auth.loschke.ai/api/auth/oauth2/end-session
OIDC_JWKS_URL=https://auth.loschke.ai/api/auth/jwks
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3000/api/auth/callback
# OIDC_SCOPES="openid profile email organization"   # default

# Multi-Instanz-Gate: Login schlaegt fehl, wenn der User in loschke-auth
# keine approved Membership in der zur App gehoerenden Organization hat.
# Default: OIDC_CLIENT_ID — Konvention ist eine Org pro App, deren Slug
# dem Client-ID entspricht. Nur setzen, wenn Slug abweicht.
# AUTH_REQUIRED_ORG_SLUG=

# Eigene Base-URL der App (CSRF-Origin-Check + post_logout_redirect).
APP_BASE_URL=http://localhost:3000

# =============================================================================
# DATENBANK — Neon Postgres [PFLICHT]
# =============================================================================
# Connection-String aus dem Neon Dashboard kopieren.

DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Seed-Filter (optional): nur Seed-Files mit passendem 'instances'-Frontmatter
# werden ausgefuehrt. Konvention: Slug == OIDC_CLIENT_ID. Ohne Wert: alle
# Files werden geseedet (heutiges Default-Verhalten).
# Aufruf: SEED_INSTANCE=<slug> pnpm db:seed [--dry-run]
# SEED_INSTANCE=

# =============================================================================
# AI GATEWAY + LLM ROUTING [PFLICHT fuer SaaS]
# =============================================================================
# Vercel AI Gateway Key — primaerer Chat-Zugang fuer alle Modelle (SaaS).
#
# LLM_ROUTING bestimmt wie Model-IDs zu Providern aufgeloest werden:
#   gateway (Default) — Vercel AI Gateway, benoetigt AI_GATEWAY_API_KEY
#   direct            — Provider-SDKs direkt (EU/Local, kein Gateway noetig)
#   litellm           — Self-hosted LiteLLM Proxy als Gateway-Ersatz

# LLM_ROUTING=gateway
AI_GATEWAY_API_KEY=

# Default-Modell (optional) — ueberschreibt das isDefault-Flag in der DB.
# DEFAULT_MODEL_ID=anthropic/claude-sonnet-4-6

# --- LiteLLM (nur bei LLM_ROUTING=litellm) ---
# LITELLM_BASE_URL=http://localhost:4000/v1
# LITELLM_API_KEY=sk-litellm


# █████████████████████████████████████████████████████████████████████████████
# INSTANZ — Aussehen und Identitaet
# █████████████████████████████████████████████████████████████████████████████

# =============================================================================
# BRAND
# =============================================================================
# Bestimmt Farben, Logo, Tonalitaet der Instanz.
# Werte: lernen | unlearn | loschke | prototype

NEXT_PUBLIC_BRAND=lernen

# =============================================================================
# LANDING CONFIG (optional)
# =============================================================================
# Wenn gesetzt: laedt src/config/landings/{LANDING_CONFIG}.json und rendert
# eine schlanke Customer-Onboarding-Landing statt der build.jetzt-Marketing-Seite.
# Header-Outbound-Link (loschke.ai) und Loschke-Footer werden ausgeblendet.
# Brandfarben/Logo kommen weiterhin aus NEXT_PUBLIC_BRAND.
# Wert muss /^[a-z0-9-]+$/ entsprechen. Vorlage: src/config/landings/example.json
#
# LANDING_CONFIG=acme

# =============================================================================
# DARK MODE + THEME
# =============================================================================
# Dark Mode ist Default-an. Zum Deaktivieren: NEXT_PUBLIC_DARK_MODE=false
# Default Theme bestimmt den initialen Modus fuer neue User.

# NEXT_PUBLIC_DARK_MODE=true
NEXT_PUBLIC_DEFAULT_THEME=dark

# =============================================================================
# ADMIN
# =============================================================================
# Aktiviert /admin/* Routes und Benutzerverwaltung.
# SUPERADMIN_EMAIL: Wird beim Login automatisch zum Superadmin promotet.

# SUPERADMIN_EMAIL=admin@example.com


# █████████████████████████████████████████████████████████████████████████████
# AI-PROVIDER — Direktzugang fuer spezielle Features
# █████████████████████████████████████████████████████████████████████████████
# Provider-Keys aktivieren Features, die nicht ueber den Gateway laufen.

# =============================================================================
# ANTHROPIC — Agent Skills (PPTX, XLSX, DOCX, PDF)
# =============================================================================
# Direktzugang noetig fuer Agent Skills File-Downloads.
# Skills default: enabled. Auf "false" setzen zum Deaktivieren.

# ANTHROPIC_API_KEY=
# ANTHROPIC_SKILLS_ENABLED=true
# ANTHROPIC_STANDARD_SKILL_IDS=pptx,xlsx,docx,pdf
# ANTHROPIC_CUSTOM_SKILL_IDS=

# =============================================================================
# GOOGLE GEMINI — Bildgenerierung, YouTube-Analyse, TTS, Deep Research
# =============================================================================
# Ein Key aktiviert mehrere Features. Einzelne Features haben eigene Flags.

# GOOGLE_GENERATIVE_AI_API_KEY=

# =============================================================================
# YOUTUBE DATA API v3 — aktiviert youtube_search Tool
# =============================================================================

# YOUTUBE_API_KEY=

# =============================================================================
# GENAI-TUTOR — lernen.diy Lessons als Teaser-Cards im Chat
# =============================================================================
# Standardmaessig aktiv: Lessons werden via 'pnpm sync:lessons' aus dem
# Schwester-Repo lernen-diy nach src/data/lessons.json synchronisiert und
# vom 'lessons_search' Tool gelesen. Auf 'false' setzen um den Tutor zu
# deaktivieren (z.B. White-Label-Instanzen ohne loschke-Bezug).

# LESSONS_TUTOR_ENABLED=true

# =============================================================================
# MISTRAL — fuer Business Mode EU-Routing
# =============================================================================

# MISTRAL_API_KEY=

# =============================================================================
# IONOS AI Model Hub — EU-basiert, OpenAI-kompatibel
# =============================================================================
# Aktiviert IONOS-Modelle (Llama, Mistral, GPT-OSS) im Model-Picker.

# IONOS_API_TOKEN=

# =============================================================================
# OLLAMA — Self-hosted lokale Modelle
# =============================================================================
# Aktiviert Ollama-Modelle im Model-Picker. Benoetigt laufende Ollama-Instanz.
# Model-Format im Picker: ollama/llama3.1, ollama/mistral, etc.

# OLLAMA_BASE_URL=http://localhost:11434/v1


# █████████████████████████████████████████████████████████████████████████████
# FEATURES — Optionale Erweiterungen
# █████████████████████████████████████████████████████████████████████████████

# =============================================================================
# VOICE CHAT — Echtzeit-Sprachkonversation via Gemini Live API
# =============================================================================
# Bidirektionaler Voice Chat mit ~500ms Latenz. Benoetigt Google API Key.
# Google Search Grounding ist integriert (aktuelle Web-Infos in Voice).
# ACHTUNG: Audio wird direkt an Google gestreamt. Nicht EU/Local-kompatibel.

# VOICE_CHAT_ENABLED=true
# VOICE_CHAT_CREDITS_PER_MINUTE=5       # Credits pro Minute (Default: 5)
# VOICE_CHAT_MAX_DURATION=1800           # Max Session-Dauer in Sekunden (Default: 30 Min)
# VOICE_CHAT_DEFAULT_VOICE=Kore          # Default-Stimme (Kore, Puck, Charon, Zephyr, Aoede, Fenrir, Leda, Orus)

# =============================================================================
# DEEP RESEARCH — Gemini Deep Research Agent
# =============================================================================
# Umfassende, mehrstufige Recherche mit Report-Erstellung.
# Benoetigt: GOOGLE_GENERATIVE_AI_API_KEY
# ACHTUNG: Echte Kosten ~$3-6 pro Recherche bei Google.

# DEEP_RESEARCH_ENABLED=true

# Agent-Variante (optional, Default: max):
#   max      — gruendlich, ~$3-7/Task, bis 60 Min (deep-research-max-preview-04-2026)
#   standard — schneller, ~$1-3/Task, ~5-10 Min (deep-research-preview-04-2026)
# DEEP_RESEARCH_AGENT=max

# =============================================================================
# TEXT-TO-SPEECH — Gemini Speech Generation
# =============================================================================
# Audio-Ausgabe fuer Chat-Antworten, Podcast-Snippets, Voiceovers.
# Benoetigt: GOOGLE_GENERATIVE_AI_API_KEY + konfiguriertes Storage (R2/S3).
# Aktiv, sobald Google-Key gesetzt ist (kein zusaetzlicher ENABLED-Flag noetig).

# Model-Variante (optional, Default: flash25):
#   flash25 — gemini-2.5-flash-preview-tts (stabil, aktuell produktiv genutzt)
#   flash3  — gemini-3.1-flash-tts-preview (neu, mehr Voices + Audio-Tags, Preview-Status)
#   pro25   — gemini-2.5-pro-preview-tts (hoechste Qualitaet, teurer)
# TTS_MODEL=flash25

# =============================================================================
# GOOGLE SEARCH — Grounding with Google Search
# =============================================================================
# Schnelle, quellengestuetzte Antworten via Gemini + Google Search.
# Benoetigt: GOOGLE_GENERATIVE_AI_API_KEY

# GOOGLE_SEARCH_ENABLED=true
# GOOGLE_SEARCH_MODEL=gemini-2.5-flash

# =============================================================================
# STITCH — UI Design Generation
# =============================================================================
# Google Stitch fuer production-quality HTML-Design-Generierung.
# Benoetigt zusaetzlich: GOOGLE_GENERATIVE_AI_API_KEY

# STITCH_API_KEY=

# =============================================================================
# DESIGN-LIBRARY — Externe Prompt-Formel-Datenbank (read-only)
# =============================================================================
# Separate Neon-Datenbank mit 72 Prompt-Formeln und 1.000+ Beispielbildern.
# Aktiviert die Design-Library Galerie und das search_design_library Tool.

# DESIGN_LIBRARY_DATABASE_URL=postgresql://...

# =============================================================================
# WEB SEARCH + FETCH
# =============================================================================
# Aktiviert web_search und web_fetch Tools im Chat.
# Mindestens ein Provider-Key muss gesetzt sein.
# SEARCH_PROVIDER / FETCH_PROVIDER: firecrawl | jina | tavily | perplexity | searxng

# SEARCH_PROVIDER=firecrawl
# FETCH_PROVIDER=firecrawl
# FIRECRAWL_API_KEY=
# JINA_API_KEY=
# PERPLEXITY_API_KEY=
# TAVILY_API_KEY=
# SEARXNG_URL=http://localhost:8888

# =============================================================================
# STORAGE — S3-kompatibel (R2, MinIO, AWS S3, etc.)
# =============================================================================
# Aktiviert File-Upload und persistente Bild-Speicherung.
# Ohne Storage: Bilder als Data-URLs (funktioniert, aber groessere Payloads).
#
# Generische S3-ENVs haben Vorrang vor R2-spezifischen.
# Fuer MinIO: S3_ENDPOINT=http://minio:9000 + forcePathStyle automatisch aktiv.

# --- Generisch (MinIO, AWS S3, etc.) ---
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=loschke-chat
# S3_PUBLIC_DOMAIN=http://localhost:9000/loschke-chat
# S3_REGION=auto

# --- Cloudflare R2 (Fallback wenn S3_* nicht gesetzt) ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_DOMAIN=https://pub-xxx.r2.dev
# R2_CUSTOM_DOMAIN=https://cdn.example.com
# R2_S3_ENDPOINT=https://xxx.eu.r2.cloudflarestorage.com

# =============================================================================
# MCP — Model Context Protocol
# =============================================================================
# Aktiviert MCP-Client-Support. Server werden in der DB verwaltet (Admin-UI)
# oder ueber seeds/mcp-servers/*.md geseeded.

# MCP_ENABLED=true
# CONTEXT7_MCP_URL=https://mcp.context7.com/mcp
# CONTEXT7_API_KEY=

# =============================================================================
# MEMORY — Mem0 (Cloud oder Self-Hosted)
# =============================================================================
# Aktiviert User-Memory (automatische Extraktion + Recall).
# Ohne Key/URL: Memory-Feature komplett deaktiviert.
#
# Cloud: MEM0_API_KEY setzen (app.mem0.ai)
# Self-Hosted: MEM0_BASE_URL setzen (Docker: mem0ai/mem0:latest)
#   docker run -d -p 8080:8080 -e MEM0_BACKEND=postgres -e DATABASE_URL=... mem0ai/mem0:latest

# MEM0_API_KEY=
# MEM0_BASE_URL=http://localhost:8080
# MEMORY_SEARCH_LIMIT=10
# MEMORY_MIN_MESSAGES=6

# =============================================================================
# PROJEKT-DOKUMENTE (Defaults in Klammern)
# =============================================================================
# Limits fuer Projekt-Kontext im System-Prompt.

# PROJECT_DOCS_MAX_COUNT=10
# PROJECT_DOCS_TOKEN_BUDGET=10000
# PROJECT_DOCS_MAX_FILE_SIZE=512000
# PROJECT_DOCS_ALLOWED_EXTENSIONS=[".md", ".txt"]


# █████████████████████████████████████████████████████████████████████████████
# BETRIEB — Credits, Business Mode, Cron
# █████████████████████████████████████████████████████████████████████████████

# =============================================================================
# CREDITS
# =============================================================================
# Token-basiertes Credit-System. Skala ueber CREDITS_PER_DOLLAR steuerbar.
#
#   SaaS (mit Marge):    CREDITS_PER_DOLLAR=33  (~3x auf Token-Kosten)
#   Kostendeckung:       CREDITS_PER_DOLLAR=100 (1 Credit = 1 Cent)
#
# Siehe docs/credit-pricing-varianten.md fuer Details und Szenarien.

# NEXT_PUBLIC_CREDITS_ENABLED=true
# INITIAL_CREDITS=100                # Willkommens-Credits fuer neue User (Default: 0)
# CREDITS_PER_DOLLAR=33              # SaaS: 33, Kostendeckung: 100
# FALLBACK_INPUT_PRICE=1.0           # Fallback $/1M Input-Tokens
# FALLBACK_OUTPUT_PRICE=5.0          # Fallback $/1M Output-Tokens

# Tool-Flatrates (Credits)            SaaS    Kostendeckung
# IMAGE_GENERATION_CREDITS=15        # 15      8
# DEEP_RESEARCH_CREDITS=800          # 800     400
# YOUTUBE_SEARCH_CREDITS=2           # 2       1
# YOUTUBE_ANALYZE_CREDITS=10         # 10      5
# TTS_CREDITS=5                      # 5       3
# BRANDING_CREDITS=2                 # 2       1
# STITCH_GENERATION_CREDITS=10       # 10      5
# GOOGLE_SEARCH_CREDITS=2            # 2       1
# VOICE_CHAT_CREDITS_PER_MINUTE=5    # 8       5

# =============================================================================
# USER SKILLS — Nutzer koennen eigene Skills erstellen
# =============================================================================
# Deaktiviert: Nur Admin-Skills verfuegbar. Workspace zeigt keinen Skills-Tab.
# NEXT_PUBLIC_USER_SKILLS_ENABLED=true

# =============================================================================
# MODEL PICKER (POWER-USER) — Modellwechsel pro Nachricht im Prompt-Input
# =============================================================================
# Aktiviert ein Modell-Dropdown im Prompt-Input neben dem Expert-Switch.
# Power-User koennen damit pro Nachricht das Modell wechseln und Antworten
# direkt vergleichen. Aktiviert zusaetzlich ein dauerhaft sichtbares
# Modell-Badge an Assistant-Messages (sonst nur on-hover).
#
# Default (nicht gesetzt): Aus. Nur ein festes Standard-Modell pro Chat.
# Empfohlen nur in Instanzen mit hohem Power-User-Anteil.
# NEXT_PUBLIC_MODEL_PICKER_ENABLED=true

# =============================================================================
# OFFENE REGISTRIERUNG — Selbstregistrierung ohne Admin-Freischaltung
# =============================================================================
# Default (nicht gesetzt): Neue User muessen von Admin/Superadmin freigeschaltet werden.
# Aktiviert: Selbstregistrierung ohne Freischaltung moeglich.

# NEXT_PUBLIC_OPEN_REGISTRATION=true

# =============================================================================
# BUSINESS MODE — Datenschutz + PII-Erkennung
# =============================================================================
# Aktiviert PII-Erkennung, Consent-Flow, Privacy-Routing und SafeChat.
# Ohne NEXT_PUBLIC_BUSINESS_MODE=true sind alle folgenden Variablen wirkungslos.

# NEXT_PUBLIC_BUSINESS_MODE=true

# PII-Erkennung: Methode (aktuell nur "regex", lokal ohne API-Call)
# BUSINESS_MODE_PII_DETECTION=regex

# Link zur Datenschutzerklaerung (optional, wird im UI angezeigt)
# BUSINESS_MODE_PRIVACY_URL=https://example.com/datenschutz

# --- Privacy-Modelle ---
# Mindestens eines muss gesetzt sein, damit SafeChat und Privacy-Routing funktionieren.
#
# EU-Modell: Mistral (Paris, DSGVO-konform). Nutzt @ai-sdk/mistral direkt, kein Gateway.
# BUSINESS_MODE_EU_MODEL=mistral-large-latest
#
# DE-Modell: IONOS (Frankfurt, deutsches Hosting). Braucht zusaetzlich IONOS_API_TOKEN.
# BUSINESS_MODE_DE_MODEL=ionos/meta-llama/Llama-3.3-70B-Instruct
#
# Lokales Modell: Ollama oder anderer OpenAI-kompatibler Server. Kein Datenabfluss.
# BUSINESS_MODE_LOCAL_MODEL=llama3.1
# BUSINESS_MODE_LOCAL_URL=http://localhost:11434/v1

# --- SafeChat ---
# Proaktiver Datenschutz-Modus: User aktiviert SafeChat BEVOR er tippt.
# Alle Nachrichten werden automatisch ueber das konfigurierte Privacy-Modell geroutet,
# ohne dass der PII-Dialog erscheint.
#
# SafeChat ist automatisch verfuegbar sobald Business Mode aktiv ist UND
# mindestens ein Privacy-Modell (EU, DE oder Local) konfiguriert ist.
#
# Default-Route fuer den "Sicher"-Modus: "eu" oder "de".
# Bestimmt welches Cloud-Modell SafeChat nutzt. "local" als zweite Option
# (Ollama) wird im UI separat angeboten, wenn konfiguriert.
# BUSINESS_MODE_SAFE_CHAT_ROUTE=eu
#
# Anzeigename im UI (optional, Default: "SafeChat")
# BUSINESS_MODE_SAFE_CHAT_LABEL=SafeChat

# =============================================================================
# CRON JOBS
# =============================================================================
# Chat Retention: Loescht nicht-angepinnte Chats nach X Tagen.
# Vercel Cron laeuft taeglich um 3 Uhr (vercel.json).
# CRON_SECRET schuetzt den Endpunkt vor unautorisiertem Zugriff.

# CRON_SECRET=mindestens-32-zeichen-langer-geheimer-schluessel
# CHAT_RETENTION_DAYS=90
