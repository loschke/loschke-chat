# Brand (lernen | unlearn | loschke | prototype | aok)
NEXT_PUBLIC_BRAND=lernen

# Logto Auth (OIDC)
LOGTO_APP_ID=
LOGTO_APP_SECRET=
LOGTO_ENDPOINT=https://auth.lernen.diy
LOGTO_BASE_URL=http://localhost:3000
LOGTO_COOKIE_SECRET=mindestens-32-zeichen-langer-geheimer-schluessel

# Neon Database
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Vercel AI Gateway (Chat Feature)
AI_GATEWAY_API_KEY=

# Feature Flags
# Steuert sowohl Sidebar-Chat als auch Fullpage-Assistent
NEXT_PUBLIC_CHAT_ENABLED=true

# Dark Mode (opt-out: entfernen oder "false" setzen zum Deaktivieren)
# NEXT_PUBLIC_DARK_MODE=false
# Default Theme: "light" | "dark" | "system"
NEXT_PUBLIC_DEFAULT_THEME=light

# Cloudflare R2 Storage (optional)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_DOMAIN=assets.lernen.diy

# Web Search/Fetch Provider (optional, default: firecrawl)
# Search and fetch can use different providers, e.g. Perplexity for search + Jina for fetch
# SEARCH_PROVIDER=firecrawl
# FETCH_PROVIDER=jina
FIRECRAWL_API_KEY=
# JINA_API_KEY=
# PERPLEXITY_API_KEY=
# TAVILY_API_KEY=

# MCP - Model Context Protocol (optional)
# Set to "true" to enable MCP client support. Individual servers are configured
# in src/config/mcp.ts and gated by their own env vars.
# MCP_ENABLED=true
