# =============================================================================
# loschke-chat — Environment Variables
# =============================================================================
#
# Kopiere diese Datei nach .env und fuelle die Werte aus.
# Nur die mit [PFLICHT] markierten Variablen sind fuer den Start noetig.
# Alles andere aktiviert optionale Features.
#
# Feature-Aktivierung:
#   - Opt-out (Default an):  chat, mermaid, darkMode
#   - Opt-in (Key setzen):   web/search, storage, mcp, admin, memory, imageGeneration
#   - Opt-in (Flag setzen):  businessMode, credits
#

# =============================================================================
# AUTH — Logto OIDC [PFLICHT]
# =============================================================================
# Logto App im Dashboard anlegen → Application ID + Secret kopieren.
# Ohne diese Werte: Dev-Bypass (alles frei zugaenglich).

LOGTO_APP_ID=
LOGTO_APP_SECRET=
LOGTO_ENDPOINT=https://auth.example.com
LOGTO_BASE_URL=http://localhost:3000
LOGTO_COOKIE_SECRET=mindestens-32-zeichen-langer-geheimer-schluessel

# =============================================================================
# DATENBANK — Neon Postgres [PFLICHT]
# =============================================================================
# Connection-String aus dem Neon Dashboard kopieren.

DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# =============================================================================
# AI — Gateway + Provider Keys [PFLICHT: mindestens Gateway]
# =============================================================================
# AI_GATEWAY_API_KEY: Vercel AI Gateway Key (primaerer Chat-Zugang)
# Provider-Keys: Direkt-Zugang fuer spezielle Features

AI_GATEWAY_API_KEY=

# Anthropic — Direktzugang (optional, fuer Fallback/Testing)
# ANTHROPIC_API_KEY=

# Google Gemini — aktiviert Bildgenerierung (generate_image Tool)
# GOOGLE_GENERATIVE_AI_API_KEY=

# Mistral — fuer Business Mode EU-Routing
# MISTRAL_API_KEY=

# =============================================================================
# BRAND — Instanz-Konfiguration
# =============================================================================
# Bestimmt Farben, Logo, Tonalitaet der Instanz.
# Werte: lernen | unlearn | loschke | prototype

NEXT_PUBLIC_BRAND=lernen

# =============================================================================
# DARK MODE + THEME
# =============================================================================
# Dark Mode ist Default-an. Zum Deaktivieren: NEXT_PUBLIC_DARK_MODE=false
# Default Theme bestimmt den initialen Modus fuer neue User.

# NEXT_PUBLIC_DARK_MODE=true
NEXT_PUBLIC_DEFAULT_THEME=dark

# =============================================================================
# ADMIN (optional)
# =============================================================================
# Aktiviert /admin/* Routes und Benutzerverwaltung.
# SUPERADMIN_EMAIL: Wird beim Login automatisch zum Superadmin promotet (DB-Rolle).
# ADMIN_EMAILS: Deprecated Fallback — komma-separierte E-Mail-Adressen.

# SUPERADMIN_EMAIL=admin@example.com
# ADMIN_EMAILS=admin@example.com

# =============================================================================
# WEB SEARCH + FETCH (optional)
# =============================================================================
# Aktiviert web_search und web_fetch Tools im Chat.
# Mindestens ein Provider-Key muss gesetzt sein.
#
# SEARCH_PROVIDER / FETCH_PROVIDER: firecrawl | jina | tavily | perplexity
# Default: firecrawl (wenn FIRECRAWL_API_KEY gesetzt)
# Search und Fetch koennen unterschiedliche Provider nutzen.

# SEARCH_PROVIDER=firecrawl
# FETCH_PROVIDER=firecrawl

# FIRECRAWL_API_KEY=
# JINA_API_KEY=
# PERPLEXITY_API_KEY=
# TAVILY_API_KEY=

# =============================================================================
# STORAGE — Cloudflare R2 (optional)
# =============================================================================
# Aktiviert File-Upload und persistente Bild-Speicherung.
# Ohne R2: Bilder als Data-URLs (funktioniert, aber groessere Payloads).

# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_DOMAIN=https://pub-xxx.r2.dev
# R2_CUSTOM_DOMAIN=https://cdn.example.com
# R2_S3_ENDPOINT=https://xxx.eu.r2.cloudflarestorage.com

# =============================================================================
# MCP — Model Context Protocol (optional)
# =============================================================================
# Aktiviert MCP-Client-Support. Server werden in der DB verwaltet (Admin-UI)
# oder ueber seeds/mcp-servers/*.md geseeded.

# MCP_ENABLED=true

# Context7 MCP (Dokumentations-Lookup fuer AI SDK, Next.js etc.)
# CONTEXT7_MCP_URL=https://mcp.context7.com/mcp
# CONTEXT7_API_KEY=

# =============================================================================
# MEMORY — Mem0 Cloud (optional)
# =============================================================================
# Aktiviert User-Memory (automatische Extraktion + Recall).
# Ohne Key: Memory-Feature komplett deaktiviert.

# MEM0_API_KEY=
# MEMORY_SEARCH_LIMIT=10
# MEMORY_MIN_MESSAGES=6

# =============================================================================
# CREDITS (optional)
# =============================================================================
# Aktiviert Credit-System mit Token-basierter Abrechnung.
# Pricing: CREDITS_PER_DOLLAR bestimmt die Granularitaet.
# Bei 100k Credits/$ entsprechen 8000 Image-Credits = 8 Cent/Bild.

# NEXT_PUBLIC_CREDITS_ENABLED=true
# CREDITS_PER_DOLLAR=100000
# FALLBACK_INPUT_PRICE=1.0
# FALLBACK_OUTPUT_PRICE=5.0
# IMAGE_GENERATION_CREDITS=8000

# =============================================================================
# BUSINESS MODE — Datenschutz + PII-Erkennung (optional)
# =============================================================================
# Aktiviert PII-Erkennung, Consent-Flow und Privacy-Routing.

# NEXT_PUBLIC_BUSINESS_MODE=true
# BUSINESS_MODE_PII_DETECTION=regex
# BUSINESS_MODE_EU_MODEL=mistral-large-latest
# BUSINESS_MODE_PRIVACY_URL=
# BUSINESS_MODE_LOCAL_MODEL=llama3.1
# BUSINESS_MODE_LOCAL_URL=http://localhost:11434/v1

# =============================================================================
# PROJEKT-DOKUMENTE (optional, Defaults in Klammern)
# =============================================================================
# Limits fuer Projekt-Kontext im System-Prompt.

# PROJECT_DOCS_MAX_COUNT=10
# PROJECT_DOCS_TOKEN_BUDGET=10000
# PROJECT_DOCS_MAX_FILE_SIZE=512000
# PROJECT_DOCS_ALLOWED_EXTENSIONS=[".md", ".txt"]

# =============================================================================
# CRON JOBS (optional)
# =============================================================================
# Chat Retention: Loescht nicht-angepinnte Chats nach X Tagen.
# Vercel Cron laeuft taeglich um 3 Uhr (vercel.json).
# CRON_SECRET schuetzt den Endpunkt vor unautorisiertem Zugriff.

# CRON_SECRET=mindestens-32-zeichen-langer-geheimer-schluessel
# CHAT_RETENTION_DAYS=90
